# Copy this file to infra/.env.deploy and fill in your real values.
# This file is gitignored.

# Public IPs of the Azure VMs
BACKEND_HOST=20.0.0.0
FRONTEND_HOST=20.0.0.0

# SSH user (Azure default is azureuser)
SSH_USER=azureuser

# SSH key files (relative to repo root)
BACKEND_KEY=backend_key.pem
FRONTEND_KEY=frontend_key.pem

# Backend secrets (will be written to /srv/dogcare-api/.env on the backend VM)
JWT_SECRET=change-me-to-a-long-random-string
DB_PASSWORD=change-me-too

# Backend exposed port (NSG must allow this from the frontend VM)
API_PORT=3000
